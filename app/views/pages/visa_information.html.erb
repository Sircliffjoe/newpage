<% content_for :title, "Visa Assistance & Information | Newpage Integrity Travels & Tours" %>

<!-- Hero -->
<section class="relative py-24 bg-brand-blue-dark">
  <div class="absolute inset-0 z-0">
    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?q=80&w=2070&auto=format&fit=crop" alt="Passport and Visas" class="w-full h-full object-cover opacity-20 mix-blend-overlay">
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6">Expert Visa Assistance</h1>
    <p class="text-xl text-brand-blue-100 max-w-3xl mx-auto">We simplify the complex visa application process, giving you the highest chance of approval for tourism, study, work, or business.</p>
  </div>
</section>

<!-- Visa Types -->
<section class="py-20 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Tourist Visa -->
      <div class="bg-white rounded-2xl shadow-soft p-8 border-t-4 border-brand-red hover:-translate-y-2 transition-transform duration-300">
        <h3 class="font-heading font-bold text-2xl text-brand-gray-900 mb-4">Tourist Visa</h3>
        <p class="text-gray-600 mb-6">Explore the world with ease. We help you gather the right documents, book appointments, and prepare for interviews for tourist visas to the US, UK, Canada, Schengen Area, and more.</p>
        <ul class="space-y-2 text-gray-500 mb-8 text-sm">
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Document Review</li>
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Form Filling</li>
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Interview Prep</li>
        </ul>
        <a href="#consultation" class="block w-full text-center bg-brand-gray-50 hover:bg-brand-blue hover:text-white text-brand-blue font-semibold py-3 rounded-xl transition-colors">Apply Now</a>
      </div>

      <!-- Student Visa -->
      <div class="bg-white rounded-2xl shadow-soft p-8 border-t-4 border-brand-blue hover:-translate-y-2 transition-transform duration-300">
        <h3 class="font-heading font-bold text-2xl text-brand-gray-900 mb-4">Student Visa</h3>
        <p class="text-gray-600 mb-6">Secure your future. Once admitted to a foreign institution, we guide you through the financial documentation and visa procedures required for international students.</p>
        <ul class="space-y-2 text-gray-500 mb-8 text-sm">
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Financial Proof Guidance</li>
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Statement of Purpose</li>
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Embassy Liaison</li>
        </ul>
        <a href="#consultation" class="block w-full text-center bg-brand-gray-50 hover:bg-brand-blue hover:text-white text-brand-blue font-semibold py-3 rounded-xl transition-colors">Apply Now</a>
      </div>

      <!-- Business/Work Visa -->
      <div class="bg-white rounded-2xl shadow-soft p-8 border-t-4 border-green-500 hover:-translate-y-2 transition-transform duration-300">
        <h3 class="font-heading font-bold text-2xl text-brand-gray-900 mb-4">Business / Work Visa</h3>
        <p class="text-gray-600 mb-6">Expand your professional horizons. We assist corporate executives, investors, and skilled workers in obtaining the necessary permits to work or conduct business abroad.</p>
        <ul class="space-y-2 text-gray-500 mb-8 text-sm">
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Sponsorship Processing</li>
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Corporate Documentation</li>
          <li class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Legal Compliance</li>
        </ul>
        <a href="#consultation" class="block w-full text-center bg-brand-gray-50 hover:bg-brand-blue hover:text-white text-brand-blue font-semibold py-3 rounded-xl transition-colors">Apply Now</a>
      </div>
      
    </div>
  </div>
</section>

<!-- Consultation Form -->
<section id="consultation" class="py-20 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-brand-blue-dark rounded-3xl shadow-2xl p-8 md:p-12">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl font-bold text-white mb-4">Request a Visa Consultation</h2>
        <p class="text-brand-blue-100">Fill out the form below and one of our immigration experts will contact you within 24 hours.</p>
      </div>

      <form action="<%= contacts_path %>" method="POST" class="space-y-6">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <input type="hidden" name="contact_submission[subject]" value="Visa Consultation Request">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-brand-blue-100 mb-2">Full Name</label>
            <input type="text" name="contact_submission[name]" required class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-brand-red">
          </div>
          <div>
            <label class="block text-sm font-medium text-brand-blue-100 mb-2">Email Address</label>
            <input type="email" name="contact_submission[email]" required class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-brand-red">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-brand-blue-100 mb-2">Phone Number / WhatsApp</label>
          <input type="tel" name="contact_submission[phone]" required class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-brand-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-brand-blue-100 mb-2">Visa Type & Destination Country</label>
          <textarea name="contact_submission[message]" rows="4" required placeholder="E.g., I need a tourist visa to Canada..." class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-brand-red"></textarea>
        </div>

        <button type="submit" class="w-full bg-brand-red hover:bg-brand-red-light text-white font-bold text-lg py-4 rounded-xl transition-colors shadow-lg">
          Submit Request
        </button>
      </form>
    </div>
  </div>
</section>
