<% content_for :title, "#{@destination.name} | Newpage Integrity Travels & Tours" %>

<!-- Hero -->
<section class="relative py-24 bg-brand-blue-dark">
  <% if @destination.hero_image.attached? %>
    <div class="absolute inset-0 z-0">
      <%= image_tag @destination.hero_image, class: "w-full h-full object-cover opacity-20 mix-blend-overlay" %>
    </div>
  <% end %>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="inline-block px-4 py-1 rounded-full bg-white/10 text-white text-sm font-semibold mb-4"><%= @destination.category&.humanize %> Destination</span>
    <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-4"><%= @destination.name %></h1>
    <% if @destination.cost_estimate.present? %>
      <p class="text-brand-red-light text-xl font-semibold">Starting from <%= @destination.cost_estimate %></p>
    <% end %>
  </div>
</section>

<!-- Content -->
<section class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="prose prose-lg max-w-none mb-12">
      <%= @destination.description %>
    </div>

    <% if @destination.requirements.present? %>
      <div class="bg-brand-gray-50 rounded-2xl p-8 mb-8">
        <h2 class="font-heading text-2xl font-bold text-brand-gray-900 mb-6">Requirements</h2>
        <ul class="space-y-3">
          <% @destination.requirements.split("\n").reject(&:blank?).each do |req| %>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span class="text-gray-700"><%= req.strip %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- CTA -->
    <div class="bg-gradient-to-r from-brand-blue to-brand-blue-dark rounded-2xl p-8 text-center text-white">
      <h3 class="font-heading text-2xl font-bold mb-4">Plan Your Trip to <%= @destination.name %></h3>
      <p class="mb-6 opacity-90">Speak with our travel consultants to get personalized packages and visa guidance.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Send Inquiry", contact_path(subject: "Inquiry about #{@destination.name}"), class: "bg-white text-brand-blue font-bold py-3 px-8 rounded-full hover:bg-gray-100 transition-colors" %>
        <a href="https://wa.me/2348038656409?text=Hello,%20I%20am%20interested%20in%20travelling%20to%20<%= CGI.escape(@destination.name) %>." target="_blank" class="bg-[#25D366] text-white font-bold py-3 px-8 rounded-full hover:bg-[#20b858] transition-colors">WhatsApp Us</a>
      </div>
    </div>
  </div>
</section>
