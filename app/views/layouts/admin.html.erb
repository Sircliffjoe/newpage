<!DOCTYPE html>
<html>
  <head>
    <title>Admin Dashboard | Newpage</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-100 font-sans text-gray-900 h-screen flex overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-brand-blue-dark text-white flex-shrink-0 overflow-y-auto">
      <div class="p-6">
        <h2 class="text-2xl font-bold font-heading">Newpage <span class="text-brand-red">Admin</span></h2>
      </div>
      <nav class="mt-6 px-4 space-y-2">
        <%= link_to "Dashboard", admin_root_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Leads", admin_leads_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Services", admin_services_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Destinations", admin_destinations_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Blog Posts", admin_blog_posts_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Blog Categories", admin_blog_categories_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Testimonials", admin_testimonials_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "Gallery", admin_gallery_images_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        <%= link_to "FAQs", admin_faqs_path, class: "block px-4 py-2 rounded hover:bg-white/10" %>
        
        <div class="pt-8 mt-8 border-t border-white/20">
          <%= link_to "Back to Website", root_path, class: "block px-4 py-2 rounded hover:bg-white/10 text-gray-400" %>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "w-full text-left px-4 py-2 rounded hover:bg-white/10 text-brand-red-light mt-2" %>
        </div>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden">
      <header class="bg-white shadow-sm h-16 flex items-center justify-between px-8 flex-shrink-0">
        <h1 class="text-xl font-semibold"><%= yield(:header) || "Dashboard" %></h1>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium"><%= current_user&.email %></span>
          <span class="px-2 py-1 bg-brand-blue/10 text-brand-blue rounded text-xs font-bold uppercase"><%= current_user&.role %></span>
        </div>
      </header>

      <div class="flex-1 overflow-auto p-8">
        <% if notice %>
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6"><%= alert %></div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
