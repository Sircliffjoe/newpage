<% content_for :title, "Contact Us | Newpage Integrity Travels & Tours" %>

<!-- Header -->
<section class="pt-32 pb-16 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-heading text-4xl md:text-5xl font-bold text-brand-gray-900 mb-4">Contact Us</h1>
    <p class="text-lg text-gray-500 max-w-2xl mx-auto">We are here to help you. Reach out to us for inquiries regarding travel, visas, study abroad, or corporate services.</p>
  </div>
</section>

<!-- Content -->
<section class="py-12 bg-white mb-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      <!-- Contact Info & Map -->
      <div>
        <h2 class="font-heading text-2xl font-bold text-brand-gray-900 mb-8">Get In Touch</h2>
        
        <div class="space-y-6 mb-12">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-blue/10 text-brand-blue rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <h4 class="font-bold text-brand-gray-900">Office Address</h4>
              <p class="text-gray-500 mt-1 leading-relaxed">No 4 Airport Road<br/>Opposite Kosini junction,<br/>Warri, Delta State, Nigeria.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-blue/10 text-brand-blue rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <h4 class="font-bold text-brand-gray-900">Phone & WhatsApp</h4>
              <p class="text-gray-500 mt-1"><a href="tel:+2348038656409" class="hover:text-brand-blue">+234 803 865 6409</a></p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-blue/10 text-brand-blue rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h4 class="font-bold text-brand-gray-900">Email Address</h4>
              <p class="text-gray-500 mt-1"><a href="mailto:newpageintegritytravels@gmail.com" class="hover:text-brand-blue">newpageintegritytravels@gmail.com</a></p>
            </div>
          </div>
        </div>

        <!-- Embedded Map -->
        <div class="w-full h-64 bg-gray-200 rounded-2xl overflow-hidden shadow-inner">
          <!-- Note: Use actual coordinates/embed link for the specific address -->
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15873.344810777977!2d5.751351110006766!3d5.531238917822997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1041ad48b8df2279%3A0xc3041935e6ba268c!2sAirport%20Rd%2C%20Warri%2C%20Delta!5e0!3m2!1sen!2sng!4v1700000000000!5m2!1sen!2sng" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-brand-gray-50 p-8 md:p-10 rounded-3xl shadow-soft">
        <h2 class="font-heading text-2xl font-bold text-brand-gray-900 mb-6">Send us a Message</h2>
        
        <form action="<%= contact_path %>" method="POST" class="space-y-6">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Full Name <span class="text-brand-red">*</span></label>
            <input type="text" name="contact_submission[name]" required class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Email Address <span class="text-brand-red">*</span></label>
              <input type="email" name="contact_submission[email]" required class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
              <input type="tel" name="contact_submission[phone]" class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent">
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Subject</label>
            <input type="text" name="contact_submission[subject]" value="<%= params[:subject] %>" class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Your Message <span class="text-brand-red">*</span></label>
            <textarea name="contact_submission[message]" rows="5" required class="w-full bg-white border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent"></textarea>
          </div>

          <button type="submit" class="w-full bg-brand-blue hover:bg-brand-blue-dark text-white font-bold text-lg py-4 rounded-xl transition-colors shadow-md">
            Send Message
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
