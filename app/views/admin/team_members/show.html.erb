<div class="p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @team_member.name %></h1>
    <div class="flex gap-3">
      <%= link_to "Edit", edit_admin_team_member_path(@team_member), class: "bg-yellow-600 text-white px-4 py-2 rounded-lg hover:bg-yellow-700" %>
      <%= link_to "Back to Team", admin_team_members_path, class: "bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="md:col-span-1">
      <div class="bg-white shadow sm:rounded-lg p-6 text-center">
        <% if @team_member.image.attached? %>
          <%= image_tag @team_member.image, class: "h-32 w-32 rounded-full object-cover mx-auto mb-4" %>
        <% else %>
          <div class="h-32 w-32 rounded-full bg-gray-200 mx-auto mb-4 flex items-center justify-center">
            <span class="text-4xl text-gray-400"><%= @team_member.name.first %></span>
          </div>
        <% end %>
        <h2 class="text-xl font-bold text-gray-900"><%= @team_member.name %></h2>
        <p class="text-gray-500"><%= @team_member.position %></p>
      </div>
    </div>

    <div class="md:col-span-2">
      <div class="bg-white shadow sm:rounded-lg p-6 space-y-4">
        <div>
          <dt class="text-sm font-medium text-gray-500">Email</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @team_member.email.presence || "Not provided" %></dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Phone</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @team_member.phone.presence || "Not provided" %></dd>
        </div>

        <div>
          <dt class="text-sm font-medium text-gray-500">Bio</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @team_member.bio.presence || "No bio" %></dd>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">LinkedIn</dt>
            <dd class="mt-1 text-sm">
              <% if @team_member.linkedin.present? %>
                <%= link_to "View Profile", @team_member.linkedin, target: "_blank", class: "text-blue-600 hover:underline" %>
              <% else %>
                <span class="text-gray-400">Not provided</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Twitter</dt>
            <dd class="mt-1 text-sm">
              <% if @team_member.twitter.present? %>
                <%= link_to "View Profile", @team_member.twitter, target: "_blank", class: "text-blue-600 hover:underline" %>
              <% else %>
                <span class="text-gray-400">Not provided</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Facebook</dt>
            <dd class="mt-1 text-sm">
              <% if @team_member.facebook.present? %>
                <%= link_to "View Profile", @team_member.facebook, target: "_blank", class: "text-blue-600 hover:underline" %>
              <% else %>
                <span class="text-gray-400">Not provided</span>
              <% end %>
            </dd>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
