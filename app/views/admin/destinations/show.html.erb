<div class="p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @destination.name %></h1>
    <div class="flex gap-3">
      <%= link_to "Edit", edit_admin_destination_path(@destination), class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
      <%= link_to "Back to Destinations", admin_destinations_path, class: "bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700" %>
    </div>
  </div>

  <div class="bg-white shadow sm:rounded-lg p-6 space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <dt class="text-sm font-medium text-gray-500">Country</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @destination.country %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Category</dt>
        <dd class="mt-1"><span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800"><%= @destination.category.humanize %></span></dd>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <dt class="text-sm font-medium text-gray-500">Visa Required</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @destination.visa_required? ? "Yes" : "No" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Cost Range</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @destination.cost_range.presence || "N/A" %></dd>
      </div>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500">Status</dt>
      <dd class="mt-1">
        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= @destination.active? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
          <%= @destination.active? ? 'Active' : 'Inactive' %>
        </span>
      </dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500">Short Description</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @destination.short_description %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500">Description</dt>
      <dd class="mt-1 prose max-w-none"><%= @destination.description %></dd>
    </div>

    <% if @destination.hero_image.attached? %>
      <div>
        <dt class="text-sm font-medium text-gray-500">Hero Image</dt>
        <dd class="mt-1"><%= image_tag @destination.hero_image, class: "h-48 w-auto rounded-lg" %></dd>
      </div>
    <% end %>
  </div>
</div>
