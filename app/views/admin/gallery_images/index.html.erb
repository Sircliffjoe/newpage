<div class="p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Gallery Images</h1>
    <%= link_to "New Image", new_admin_gallery_image_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    <% @gallery_images.each do |image| %>
      <div class="relative group bg-white rounded-lg shadow overflow-hidden">
        <% if image.file.attached? %>
          <%= image_tag image.file, class: "w-full h-48 object-cover" %>
        <% end %>
        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-50 transition-all flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100">
          <%= link_to "Edit", edit_admin_gallery_image_path(image), class: "bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700" %>
          <%= button_to "Delete", admin_gallery_image_path(image), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-600 text-white px-3 py-1 rounded text-sm hover:bg-red-700" %>
        </div>
        <div class="p-2">
          <p class="text-sm text-gray-600 truncate"><%= image.caption.presence || "No caption" %></p>
          <p class="text-xs text-gray-400"><%= image.category.presence || "General" %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
