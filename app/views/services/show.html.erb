<% content_for :title, "#{@service.title} | Newpage Integrity Travels & Tours" %>

<!-- Hero -->
<section class="relative py-24 bg-brand-blue-dark">
  <% if @service.hero_image.attached? %>
    <div class="absolute inset-0 z-0">
      <%= image_tag @service.hero_image, class: "w-full h-full object-cover opacity-20 mix-blend-overlay" %>
    </div>
  <% end %>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="inline-block px-4 py-1 rounded-full bg-brand-red/20 text-brand-red-light border border-brand-red/30 text-sm font-semibold mb-4"><%= @service.category.humanize %></span>
    <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4"><%= @service.title %></h1>
  </div>
</section>

<!-- Content -->
<section class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="prose prose-lg max-w-none mb-12">
      <%= @service.description %>
    </div>

    <% if @service.benefits.present? %>
      <div class="bg-brand-gray-50 rounded-2xl p-8 mb-8">
        <h2 class="font-heading text-2xl font-bold text-brand-gray-900 mb-6">Benefits</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @service.benefits.split("\n").reject(&:blank?).each do |benefit| %>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-gray-700"><%= benefit.strip %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @service.requirements.present? %>
      <div class="bg-blue-50 rounded-2xl p-8 mb-8">
        <h2 class="font-heading text-2xl font-bold text-brand-gray-900 mb-6">Requirements</h2>
        <ul class="space-y-3">
          <% @service.requirements.split("\n").reject(&:blank?).each do |req| %>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              <span class="text-gray-700"><%= req.strip %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- CTA -->
    <div class="bg-brand-blue rounded-2xl p-8 text-center text-white">
      <h3 class="font-heading text-2xl font-bold mb-4">Interested in this service?</h3>
      <p class="mb-6 opacity-90">Let's discuss your needs. Book a free consultation or chat with us directly.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Book Consultation", contact_path(subject: @service.title), class: "bg-white text-brand-blue font-bold py-3 px-8 rounded-full hover:bg-gray-100 transition-colors" %>
        <a href="https://wa.me/2348038656409?text=Hello,%20I%20am%20interested%20in%20your%20<%= CGI.escape(@service.title) %>%20service." target="_blank" class="bg-[#25D366] text-white font-bold py-3 px-8 rounded-full hover:bg-[#20b858] transition-colors flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Related Services -->
<% if @related_services.any? %>
  <section class="py-16 bg-brand-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-brand-gray-900 mb-8">Related Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% @related_services.each do |service| %>
          <div class="bg-white rounded-2xl shadow-soft p-6 hover:-translate-y-1 transition-transform duration-300">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-brand-blue/10 text-brand-blue mb-3"><%= service.category.humanize %></span>
            <h3 class="font-heading font-bold text-lg text-brand-gray-900 mb-2"><%= service.title %></h3>
            <p class="text-gray-500 text-sm mb-4"><%= strip_tags(service.description.to_s).truncate(80) %></p>
            <%= link_to "View Details →", service_path(slug: service.slug), class: "text-brand-blue font-semibold text-sm" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
