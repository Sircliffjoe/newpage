<% content_for :title, "Our Services | Newpage Integrity Travels & Tours" %>

<!-- Hero -->
<section class="relative py-24 bg-brand-blue-dark">
  <div class="absolute inset-0 z-0">
    <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?q=80&w=2069&auto=format&fit=crop" alt="Services" class="w-full h-full object-cover opacity-20 mix-blend-overlay">
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6">Our Services</h1>
    <p class="text-xl text-gray-300 max-w-3xl mx-auto">From travel bookings to corporate registrations, we provide end-to-end professional services.</p>
  </div>
</section>

<!-- Category Filter -->
<section class="py-8 bg-white border-b border-gray-100 sticky top-20 z-30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap gap-3 justify-center">
      <%= link_to "All Services", services_path, class: "px-5 py-2 rounded-full text-sm font-medium transition-colors #{params[:category].blank? ? 'bg-brand-blue text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
      <%= link_to "Travel & Tours", services_path(category: 'travel'), class: "px-5 py-2 rounded-full text-sm font-medium transition-colors #{params[:category] == 'travel' ? 'bg-brand-blue text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
      <%= link_to "Visa Services", services_path(category: 'visa'), class: "px-5 py-2 rounded-full text-sm font-medium transition-colors #{params[:category] == 'visa' ? 'bg-brand-blue text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
      <%= link_to "Study Abroad", services_path(category: 'study_abroad'), class: "px-5 py-2 rounded-full text-sm font-medium transition-colors #{params[:category] == 'study_abroad' ? 'bg-brand-blue text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
      <%= link_to "CAC Services", services_path(category: 'cac'), class: "px-5 py-2 rounded-full text-sm font-medium transition-colors #{params[:category] == 'cac' ? 'bg-brand-blue text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
    </div>
  </div>
</section>

<!-- Services Grid -->
<section class="py-20 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @services.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @services.each do |service| %>
          <div class="bg-white rounded-2xl shadow-soft overflow-hidden group hover:-translate-y-2 transition-all duration-300">
            <div class="h-48 bg-brand-blue/10 overflow-hidden">
              <% if service.hero_image.attached? %>
                <%= image_tag service.hero_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-brand-blue to-brand-blue-light flex items-center justify-center">
                  <svg class="w-16 h-16 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
              <% end %>
            </div>
            <div class="p-6">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-brand-blue/10 text-brand-blue mb-3"><%= service.category.humanize %></span>
              <h3 class="font-heading font-bold text-xl text-brand-gray-900 mb-3"><%= service.title %></h3>
              <p class="text-gray-500 text-sm mb-4 line-clamp-3"><%= strip_tags(service.description.to_s).truncate(120) %></p>
              <%= link_to service_path(slug: service.slug), class: "inline-flex items-center text-brand-blue font-semibold text-sm hover:text-brand-blue-light" do %>
                View Details <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <svg class="w-20 h-20 text-gray-300 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        <h3 class="text-xl text-gray-400 font-medium">No services found in this category.</h3>
        <p class="text-gray-400 mt-2"><%= link_to "View all services", services_path, class: "text-brand-blue hover:underline" %></p>
      </div>
    <% end %>
  </div>
</section>
