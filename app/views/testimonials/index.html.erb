<% content_for :title, "Client Testimonials | Newpage Integrity Travels & Tours" %>

<!-- Hero -->
<section class="pt-28 pb-16 bg-brand-blue-dark text-center">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">What Our Clients Say</h1>
    <p class="text-xl text-brand-blue-100 max-w-2xl mx-auto">Real stories from people who have successfully navigated their travel, education, and business journeys with us.</p>
  </div>
</section>

<!-- Testimonials Grid -->
<section class="py-20 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @testimonials.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @testimonials.each do |testimonial| %>
          <div class="bg-white rounded-2xl p-8 shadow-soft hover:-translate-y-1 transition-transform duration-300">
            <div class="flex text-yellow-400 mb-6">
              <% (testimonial.rating || 5).times do %>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
              <% end %>
            </div>
            
            <p class="text-gray-600 mb-8 italic">"<%= testimonial.content.to_s %>"</p>
            
            <div class="flex items-center gap-4 mt-auto">
              <div class="w-12 h-12 rounded-full overflow-hidden bg-brand-blue/10 flex items-center justify-center font-bold text-brand-blue flex-shrink-0">
                <% if testimonial.image.attached? %>
                  <%= image_tag testimonial.image, class: "w-full h-full object-cover" %>
                <% else %>
                  <%= testimonial.client_name.to_s.first(2).upcase %>
                <% end %>
              </div>
              <div>
                <h4 class="font-heading font-bold text-brand-gray-900"><%= testimonial.client_name %></h4>
                <p class="text-sm text-gray-500"><%= testimonial.service_type&.humanize %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <h3 class="text-xl text-gray-400">More testimonials coming soon!</h3>
      </div>
    <% end %>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-white text-center">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="font-heading text-3xl font-bold text-brand-gray-900 mb-6">Ready to write your own success story?</h2>
    <%= link_to "Get Started Today", contact_path, class: "inline-block bg-brand-red hover:bg-brand-red-light text-white font-bold py-4 px-10 rounded-full shadow-lg transition-colors" %>
  </div>
</section>
