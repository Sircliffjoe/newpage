<% content_for :title, "Blog & News | Newpage Integrity Travels & Tours" %>

<section class="pt-28 pb-12 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-heading text-4xl font-bold text-brand-gray-900 mb-4">Latest News & Insights</h1>
    <p class="text-gray-500 max-w-2xl mx-auto">Stay informed with the latest travel tips, visa updates, and study abroad guides.</p>
  </div>
</section>

<section class="py-4 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap gap-3 justify-center">
      <%= link_to "All", blog_path, class: "px-4 py-2 rounded-full text-sm font-medium #{params[:category].blank? ? 'bg-brand-blue text-white' : 'bg-white text-gray-600 hover:bg-gray-100'} transition-colors" %>
      <% @categories.each do |cat| %>
        <%= link_to cat.name, blog_path(category: cat.id), class: "px-4 py-2 rounded-full text-sm font-medium #{params[:category].to_s == cat.id.to_s ? 'bg-brand-blue text-white' : 'bg-white text-gray-600 hover:bg-gray-100'} transition-colors" %>
      <% end %>
    </div>
  </div>
</section>

<section class="py-12 bg-brand-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @blog_posts.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @blog_posts.each do |post| %>
          <article class="bg-white rounded-2xl overflow-hidden shadow-soft group hover:-translate-y-1 transition-all duration-300">
            <div class="h-52 overflow-hidden bg-gradient-to-br from-brand-blue to-brand-blue-light">
              <% if post.featured_image.attached? %>
                <%= image_tag post.featured_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              <% end %>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-medium px-3 py-1 rounded-full bg-brand-blue/10 text-brand-blue"><%= post.blog_category.name %></span>
                <span class="text-xs text-gray-400"><%= post.published_at&.strftime("%b %d, %Y") %></span>
              </div>
              <h3 class="font-heading font-bold text-lg text-brand-gray-900 mb-2"><%= link_to post.title, blog_post_path(slug: post.slug), class: "hover:text-brand-blue" %></h3>
              <p class="text-gray-500 text-sm line-clamp-3 mb-4"><%= post.excerpt.presence || strip_tags(post.body.to_s).truncate(140) %></p>
              <%= link_to "Read More →", blog_post_path(slug: post.slug), class: "text-brand-blue font-semibold text-sm" %>
            </div>
          </article>
        <% end %>
      </div>
      <div class="mt-12 flex justify-center">
        <%== @pagy.series_nav if @pagy.pages > 1 %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <h3 class="text-xl text-gray-400">No blog posts yet. Check back soon!</h3>
      </div>
    <% end %>
  </div>
</section>
